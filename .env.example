# Optional fallback values only. Preferred setup is via the in-app Settings page.
TMDB_READ_ACCESS_TOKEN=
PORT=4173
VITE_TMDB_API_BASE=/api/tmdb
VITE_TMDB_LANGUAGE=en-US
VITE_TMDB_REGION=US

# Optional Radarr fallback integration for local/self-hosted usage only.
RADARR_HOST=
RADARR_API_KEY=
RADARR_ROOT_FOLDER=/movies
RADARR_QUALITY_PROFILE_ID=1
RADARR_MONITOR=true
RADARR_SEARCH_NOW=true
RADARR_MINIMUM_AVAILABILITY=released
RADARR_DELETE_FILES=true
RADARR_ADD_IMPORT_EXCLUSION=false

# Optional Sonarr fallback integration for local/self-hosted usage only.
SONARR_HOST=
SONARR_API_KEY=
SONARR_ROOT_FOLDER=/tv
SONARR_QUALITY_PROFILE_ID=1
SONARR_MONITOR=true
SONARR_SEARCH_NOW=true
SONARR_MONITOR_TYPE=all
SONARR_DELETE_FILES=true
SONARR_ADD_IMPORT_LIST_EXCLUSION=false
